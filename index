        // Render Compendium UI
        function renderCompendium() {
            const container = document.getElementById("compendium-list");
            container.innerHTML = "";
            
            const searchQuery = document.getElementById("compendium-search").value.toLowerCase();
            const selectedCategory = document.getElementById("compendium-category").value;

            // Filter questions based on search query and category
            const filteredQuestions = questionDatabase.filter(q => {
                const matchesSearch = q.question.toLowerCase().includes(searchQuery) || 
                                      q.explanation.toLowerCase().includes(searchQuery) ||
                                      q.answer.toLowerCase().includes(searchQuery);
                const matchesCategory = (selectedCategory === "all") || (q.category === selectedCategory);
                return matchesSearch && matchesCategory;
            });

            // Display a clean "No results found" message if the search matches nothing
            if (filteredQuestions.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-16 bg-white border border-dashed border-slate-300 rounded-3xl">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-slate-400 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        <h4 class="text-base font-extrabold text-slate-800">No Revision Concepts Match Your Filter</h4>
                        <p class="text-xs text-slate-500 mt-1">Try refining your search keyword or selecting a different category.</p>
                    </div>
                `;
                return;
            }

            // Render each question as a highly readable card
            filteredQuestions.forEach((q) => {
                const isMastered = masteredQuestions.includes(q.id);
                const card = document.createElement("div");
                card.id = `q-card-${q.id}`;
                card.className = `question-card p-6 bg-white border ${isMastered ? 'border-emerald-300 bg-emerald-50/10' : 'border-slate-200'} rounded-2xl relative flex flex-col md:flex-row gap-6 items-start justify-between`;

                // Set up the options list
                let optionsListHtml = "";
                q.options.forEach((opt, idx) => {
                    const isCorrect = (opt === q.answer);
                    optionsListHtml += `
                        <div class="flex items-start gap-2 text-xs font-semibold ${isCorrect && globalAnswersVisible ? 'text-emerald-800 font-extrabold bg-emerald-50 border-emerald-200 p-2 rounded-lg' : 'text-slate-600'}">
                            <span class="font-bold text-slate-400">${String.fromCharCode(65 + idx)}.</span>
                            <span>${opt}</span>
                            ${isCorrect && globalAnswersVisible ? '<span class="text-[9px] bg-emerald-100 text-emerald-800 px-1.5 py-0.5 rounded ml-auto">Correct Choice</span>' : ''}
                        </div>
                    `;
                });

                // Set category label colors
                let categoryColor = "bg-slate-100 text-slate-700";
                if (q.category === "macro") categoryColor = "bg-red-50 text-red-700";
                else if (q.category === "ops") categoryColor = "bg-emerald-50 text-emerald-700";
                else if (q.category === "regulatory") categoryColor = "bg-indigo-50 text-indigo-700";
                else if (q.category === "accounting") categoryColor = "bg-cyan-50 text-cyan-700";
                else if (q.category === "ific") categoryColor = "bg-amber-50 text-amber-700";

                card.innerHTML = `
                    <div class="flex-grow space-y-4 w-full">
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="text-[9px] uppercase font-black px-2.5 py-1 rounded-md ${categoryColor}">
                                ${categoryLabels[q.category]}
                            </span>
                            <span class="text-[10px] text-slate-400 font-bold">Concept Core #${q.id}</span>
                        </div>
                        <h3 class="text-sm md:text-base font-extrabold text-slate-900 leading-snug">
                            ${q.question}
                        </h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 pl-2">
                            ${optionsListHtml}
                        </div>
                        
                        <!-- Toggleable Explanation Section -->
                        <div id="explanation-${q.id}" class="${globalAnswersVisible ? '' : 'hidden'} mt-4 p-4 bg-slate-50 border border-slate-200 rounded-xl">
                            <span class="text-[10px] font-black uppercase text-slate-500 block tracking-wider mb-1">Answer Rationale & Study Hook</span>
                            <p class="text-xs text-slate-600 leading-relaxed font-medium">
                                <strong class="text-slate-900">Correct Answer:</strong> ${q.answer} <br>
                                <span class="block mt-1">${q.explanation}</span>
                            </p>
                        </div>
                        
                        <!-- Click to reveal prompt (visible only in self-test mode) -->
                        <button onclick="toggleSingleAnswer(${q.id})" class="no-print text-[10px] font-bold text-red-700 hover:text-red-800 flex items-center gap-1 ${globalAnswersVisible ? 'hidden' : 'block'}">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                            Reveal Answer & Explanation
                        </button>
                    </div>

                    <!-- Right-side progress checkboxes -->
                    <div class="no-print flex items-center gap-2 self-start md:self-center mt-4 md:mt-0 bg-slate-50 p-3 rounded-xl border border-slate-200 min-w-[150px] justify-between">
                        <label for="check-${q.id}" class="text-[11px] font-bold text-slate-600 cursor-pointer select-none">Mark Mastered</label>
                        <input type="checkbox" id="check-${q.id}" onchange="toggleMastered(${q.id})" ${isMastered ? 'checked' : ''} class="w-4 h-4 text-emerald-600 border-slate-300 rounded focus:ring-emerald-500 cursor-pointer">
                    </div>
                `;
                container.appendChild(card);
            });

            updateProgressTracker();
        }

        // Toggle answer visibility for a single question
        function toggleSingleAnswer(id) {
            const block = document.getElementById(`explanation-${id}`);
            if (block) {
                block.classList.toggle("hidden");
            }
        }

        // Global toggle to show/hide all answers
        function toggleGlobalAnswers() {
            globalAnswersVisible = !globalAnswersVisible;
            
            const btn = document.getElementById("toggle-answers-btn");
            if (globalAnswersVisible) {
                btn.innerText = "Hide All Answers (Self-Test Mode)";
                btn.className = "bg-red-700 hover:bg-red-800 text-white font-extrabold text-xs px-4 py-2.5 rounded-lg transition shadow-sm";
            } else {
                btn.innerText = "Show All Answers (Read-Through Mode)";
                btn.className = "bg-slate-800 hover:bg-slate-700 text-white font-extrabold text-xs px-4 py-2.5 rounded-lg transition shadow-sm";
            }

            renderCompendium();
        }

        // Save progress to local storage when checked
        function toggleMastered(id) {
            const idx = masteredQuestions.indexOf(id);
            const card = document.getElementById(`q-card-${id}`);

            if (idx > -1) {
                masteredQuestions.splice(idx, 1);
                if (card) {
                    card.classList.remove("border-emerald-300", "bg-emerald-50/10");
                    card.classList.add("border-slate-200");
                }
            } else {
                masteredQuestions.push(id);
                if (card) {
                    card.classList.add("border-emerald-300", "bg-emerald-50/10");
                    card.classList.remove("border-slate-200");
                }
            }

            localStorage.setItem('ific_tso_mastered', JSON.stringify(masteredQuestions));
            updateProgressTracker();
        }

        // Update progress indicators at the top of the page
        function updateProgressTracker() {
            const total = questionDatabase.length;
            const masteredCount = masteredQuestions.length;
            const percentage = Math.round((masteredCount / total) * 100);

            document.getElementById("progress-numerical").innerText = `${masteredCount} / ${total} Concepts`;
            document.getElementById("progress-slider").style.width = `${percentage}%`;
            document.getElementById("progress-percentage").innerText = `${percentage}% Done`;
        }

        // Filter search input
        function filterCompendium() {
            renderCompendium();
        }

        // Clear local progress and refresh
        function resetStudyProgress() {
            if (confirm("Are you sure you want to clear your marked progress? This will reset all your checkmarks.")) {
                masteredQuestions = [];
                localStorage.removeItem('ific_tso_mastered');
                renderCompendium();
            }
        }

        // Initialize Compendium on Load
        window.onload = function() {
            renderCompendium();
        }
    </script>
